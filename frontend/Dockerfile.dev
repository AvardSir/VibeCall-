# Frontend dev image — Vite dev server with HMR over a source bind-mount.
FROM node:22-alpine

WORKDIR /app

# Install deps in a cached layer keyed on the lockfile. node_modules lives in the
# image (and is shielded from the host by an anonymous volume in compose).
COPY package.json package-lock.json ./
RUN npm ci

# Source is bind-mounted at runtime; this COPY is only for standalone `docker build`.
COPY . .

EXPOSE 5173

CMD ["npm", "run", "dev"]
