# Backend dev image — hot-reload via tsx watch over a source bind-mount.
FROM node:22-slim

WORKDIR /app

# Install deps in a cached layer keyed on the lockfile. node_modules lives in the
# image (and is shielded from the host by an anonymous volume in compose).
COPY package.json package-lock.json ./
RUN npm ci

# Source is bind-mounted at runtime; this COPY is only for standalone `docker build`.
COPY . .

EXPOSE 3000

# server.ts contacts LiveKit on boot and exits fatally if it can't (and tsx-watch then keeps a
# dead container "running"). Wait for LiveKit's signaling port before starting so a cold
# `docker compose up` is race-free. LIVEKIT_HOST defaults to the compose service name.
CMD ["sh", "-c", "until node -e \"require('net').connect(7880,'livekit').on('connect',function(){process.exit(0)}).on('error',function(){process.exit(1)})\" 2>/dev/null; do echo 'waiting for livekit:7880...'; sleep 1; done; npm run dev"]
